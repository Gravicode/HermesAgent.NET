<?xml version="1.0" encoding="utf-8"?>
<!--
  Hermes Agent — app.config
  =========================
  Place this file in one of two locations:
    • ./app.config             — project/CWD level (highest file priority)
    • ~/.hermes/app.config     — user-level (shared across projects)

  Three configuration formats are supported and can be mixed freely.

  Priority order (highest → lowest):
    1. Command-line args
    2. Environment variables  (HERMES_Llm__ApiKey=...)
    3. ./app.config           (this file, CWD)
    4. ~/.hermes/app.config   (user-level)
    5. ~/.hermes/config.json
    6. appsettings.json
-->
<configuration>

  <!-- ═══════════════════════════════════════════════════════════════════════
       FORMAT 1 — Standard <appSettings> with IConfiguration colon keys
       Identical to appsettings.json but in XML.
       ═══════════════════════════════════════════════════════════════════════ -->
  <appSettings>

    <!-- LLM Provider -->
    <add key="Hermes:Llm:Provider"        value="openai" />
    <add key="Hermes:Llm:Model"           value="gpt-4o" />
    <add key="Hermes:Llm:ApiKey"          value="" />       <!-- or set via env var -->
    <add key="Hermes:Llm:Temperature"     value="0.7" />
    <add key="Hermes:Llm:MaxTokens"       value="4096" />
    <add key="Hermes:Llm:TimeoutSeconds"  value="120" />
    <add key="Hermes:Llm:MaxRetries"      value="3" />

    <!-- Agent loop -->
    <add key="Hermes:Agent:MaxTurns"               value="50" />
    <add key="Hermes:Agent:MaxContextTokens"       value="100000" />
    <add key="Hermes:Agent:AutoCompressContext"     value="true" />
    <add key="Hermes:Agent:CompressThresholdTokens" value="80000" />
    <add key="Hermes:Agent:EnableSkillNudging"     value="true" />
    <add key="Hermes:Agent:SkillNudgeIntervalTurns" value="10" />

    <!-- Memory -->
    <add key="Hermes:Memory:Enabled"             value="true" />
    <add key="Hermes:Memory:EnableSessionSearch" value="true" />

    <!-- Skills -->
    <add key="Hermes:Skills:Enabled"           value="true" />
    <add key="Hermes:Skills:AutoCreateSkills"  value="true" />
    <add key="Hermes:Skills:AutoImproveSkills" value="true" />

    <!-- Data directory (optional — overrides default ~/.hermes) -->
    <!-- <add key="Hermes:DataDirectory" value="C:\Users\me\.hermes" /> -->

  </appSettings>


  <!-- ═══════════════════════════════════════════════════════════════════════
       FORMAT 2 — Dot-notation shorthand keys (auto-normalized)
       Useful for brevity. Keys are case-insensitive and support dots,
       double-underscores, or colons as separators.
       ═══════════════════════════════════════════════════════════════════════ -->
  <!--
  <appSettings>
    <add key="hermes.llm.provider"              value="openrouter" />
    <add key="hermes.llm.model"                 value="openai/gpt-4o" />
    <add key="hermes.llm.apiKey"                value="sk-or-..." />
    <add key="hermes.llm.baseUrl"               value="https://openrouter.ai/api" />
    <add key="hermes.agent.maxTurns"            value="30" />
    <add key="hermes.agent.enableSkillNudging"  value="false" />
    <add key="hermes.memory.enabled"            value="true" />
  </appSettings>
  -->


  <!-- ═══════════════════════════════════════════════════════════════════════
       FORMAT 3 — Structured <hermesSettings> XML block
       Most readable. Each child element maps to a config section;
       attributes map to properties within that section.
       ═══════════════════════════════════════════════════════════════════════ -->
  <!--
  <hermesSettings>
    <llm
      provider="nous"
      model="hermes-3-70b"
      apiKey="sk-..."
      temperature="0.8"
      maxTokens="8192"
      timeoutSeconds="180"
    />
    <agent
      maxTurns="50"
      autoCompressContext="true"
      compressThresholdTokens="80000"
      enableSkillNudging="true"
      skillNudgeIntervalTurns="10"
    />
    <memory
      enabled="true"
      enableSessionSearch="true"
    />
    <skills
      enabled="true"
      autoCreateSkills="true"
      autoImproveSkills="true"
    />
  </hermesSettings>
  -->


  <!-- ═══════════════════════════════════════════════════════════════════════
       PROVIDER EXAMPLES
       Uncomment the block for your preferred provider.
       ═══════════════════════════════════════════════════════════════════════ -->

  <!-- OpenRouter (200+ models, single key) -->
  <!--
  <appSettings>
    <add key="Hermes:Llm:Provider" value="openrouter" />
    <add key="Hermes:Llm:Model"    value="meta-llama/llama-3.3-70b-instruct" />
    <add key="Hermes:Llm:ApiKey"   value="sk-or-..." />
    <add key="Hermes:Llm:BaseUrl"  value="https://openrouter.ai/api" />
  </appSettings>
  -->

  <!-- Nous Portal -->
  <!--
  <appSettings>
    <add key="Hermes:Llm:Provider" value="nous" />
    <add key="Hermes:Llm:Model"    value="hermes-3-70b" />
    <add key="Hermes:Llm:ApiKey"   value="..." />
  </appSettings>
  -->

  <!-- Local Ollama / LM Studio -->
  <!--
  <appSettings>
    <add key="Hermes:Llm:Provider" value="custom" />
    <add key="Hermes:Llm:BaseUrl"  value="http://localhost:11434/v1" />
    <add key="Hermes:Llm:Model"    value="llama3.2" />
    <add key="Hermes:Llm:ApiKey"   value="ollama" />
  </appSettings>
  -->

  <!-- Anthropic (Claude) -->
  <!--
  <appSettings>
    <add key="Hermes:Llm:Provider" value="anthropic" />
    <add key="Hermes:Llm:Model"    value="claude-sonnet-4-6" />
    <add key="Hermes:Llm:ApiKey"   value="sk-ant-..." />
  </appSettings>
  -->

</configuration>
