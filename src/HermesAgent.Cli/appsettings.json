{
  "Hermes": {
    "Llm": {
      "Provider": "openai",
      "Model": "gpt-4o",
      "ApiKey": "",
      "Temperature": 0.7,
      "MaxTokens": 4096,
      "TimeoutSeconds": 120,
      "MaxRetries": 3
    },
    "Agent": {
      "MaxTurns": 50,
      "MaxContextTokens": 100000,
      "AutoCompressContext": true,
      "CompressThresholdTokens": 80000,
      "EnableSkillNudging": true,
      "SkillNudgeIntervalTurns": 10
    },
    "Memory": {
      "Enabled": true,
      "EnableSessionSearch": true
    },
    "Skills": {
      "Enabled": true,
      "AutoCreateSkills": true,
      "AutoImproveSkills": true
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "HermesAgent": "Information"
    }
  }
}
