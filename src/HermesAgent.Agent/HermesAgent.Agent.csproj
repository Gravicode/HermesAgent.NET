<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>preview</LangVersion>
    <TreatWarningsAsErrors>false</TreatWarningsAsErrors>
    <NoWarn>$(NoWarn);CS1591</NoWarn>
    <RootNamespace>HermesAgent.Agent</RootNamespace>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\HermesAgent.Core\HermesAgent.Core.csproj" />
    <ProjectReference Include="..\HermesAgent.Tools\HermesAgent.Tools.csproj" />
    <ProjectReference Include="..\HermesAgent.Skills\HermesAgent.Skills.csproj" />
    <ProjectReference Include="..\HermesAgent.Memory\HermesAgent.Memory.csproj" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="9.0.1" />
    <PackageReference Include="Microsoft.Extensions.Logging" Version="9.0.1" />
    <PackageReference Include="Microsoft.Extensions.Options" Version="9.0.1" />
    <PackageReference Include="Polly.Core" Version="8.4.1" />
  </ItemGroup>
</Project>
