# ═══════════════════════════════════════════════════════════
#  Hermes Agent — Environment Variables
#  Copy to .env and fill in your values
# ═══════════════════════════════════════════════════════════

# ── LLM Provider ──────────────────────────────────────────
HERMES_PROVIDER=openai
HERMES_MODEL=gpt-4o
HERMES_API_KEY=sk-your-api-key-here

# For OpenRouter (200+ models):
# HERMES_PROVIDER=openrouter
# HERMES_MODEL=openai/gpt-4o
# HERMES_API_KEY=sk-or-...
# HERMES_BASE_URL=https://openrouter.ai/api

# For Nous Portal:
# HERMES_PROVIDER=nous
# HERMES_MODEL=hermes-3-70b

# For local Ollama / LM Studio:
# HERMES_PROVIDER=custom
# HERMES_BASE_URL=http://localhost:11434/v1
# HERMES_MODEL=llama3.2
# HERMES_API_KEY=ollama

# For Anthropic:
# HERMES_PROVIDER=anthropic
# HERMES_MODEL=claude-sonnet-4-6
# HERMES_API_KEY=sk-ant-...

# ── Web API ────────────────────────────────────────────────
WEB_PORT=7777

# ── Messaging Gateway ──────────────────────────────────────
WEBHOOK_PORT=7788
WEBHOOK_SECRET=change-me-to-a-random-string

# Telegram (get token from @BotFather)
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=

# Discord (create bot at discord.com/developers)
DISCORD_ENABLED=false
DISCORD_BOT_TOKEN=

# ── Image Generation ───────────────────────────────────────
FAL_KEY=

# ── Agent tuning ───────────────────────────────────────────
HERMES_Agent__MaxTurns=50
HERMES_Agent__EnableSkillNudging=true
